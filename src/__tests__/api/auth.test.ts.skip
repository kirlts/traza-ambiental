import { NextRequest } from 'next/server'
import { GET } from '@/app/api/auth/validate-rut/route'

// Mock de Prisma
jest.mock('@/lib/prisma', () => ({
  prisma: {
    user: {
      findFirst: jest.fn(),
    },
  },
}))

describe('/api/auth/validate-rut', () => {
  let mockPrisma: any

  beforeEach(() => {
    jest.clearAllMocks()
    mockPrisma = require('@/lib/prisma').prisma
  })

  it('validates existing RUT', async () => {
    // Mock user exists
    mockPrisma.user.findFirst.mockResolvedValue({
      id: '1',
      rut: '12345678-5',
      name: 'Test User',
    })

    const request = new NextRequest('http://localhost:3000/api/auth/validate-rut?rut=12345678-5')

    const response = await GET(request)
    const data = await response.json()

    expect(response.status).toBe(200)
    expect(data.exists).toBe(true)
    expect(data.user.name).toBe('Test User')
  })

  it('handles non-existing RUT', async () => {
    // Mock user doesn't exist
    mockPrisma.user.findFirst.mockResolvedValue(null)

    const request = new NextRequest('http://localhost:3000/api/auth/validate-rut?rut=99999999-9')

    const response = await GET(request)
    const data = await response.json()

    expect(response.status).toBe(200)
    expect(data.exists).toBe(false)
    expect(data.user).toBeUndefined()
  })

  it('handles missing RUT parameter', async () => {
    const request = new NextRequest('http://localhost:3000/api/auth/validate-rut')

    const response = await GET(request)
    const data = await response.json()

    expect(response.status).toBe(400)
    expect(data.error).toBe('RUT es requerido')
  })

  it('handles invalid RUT format', async () => {
    const request = new NextRequest('http://localhost:3000/api/auth/validate-rut?rut=invalid-rut')

    const response = await GET(request)
    const data = await response.json()

    expect(response.status).toBe(400)
    expect(data.error).toContain('formato inválido')
  })

  it('handles database errors', async () => {
    // Mock database error
    mockPrisma.user.findFirst.mockRejectedValue(new Error('Database connection failed'))

    const request = new NextRequest('http://localhost:3000/api/auth/validate-rut?rut=12345678-5')

    const response = await GET(request)
    const data = await response.json()

    expect(response.status).toBe(500)
    expect(data.error).toBe('Error interno del servidor')
  })
})
