yarn-error.log*
.pnpm-debug.log*
*.log
.tests-status

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma
/src/generated/prisma

# credentials/sensitive files
PASOS-DESPLIEGUE.md

