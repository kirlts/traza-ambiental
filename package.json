{
  "name": "traza-ambiental.com",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "setup:domain": "node scripts/setup-local-domain.js",
    "prisma:sync": "node scripts/sync-prisma.js",
    "dev": "next dev --turbopack",
    "predev:server": "node scripts/sync-prisma.js",
    "dev:server": "sudo next dev --turbopack -p 80 --hostname traza-ambiental.local",
    "predev:default": "node scripts/sync-prisma.js",
    "dev:default": "next dev --turbopack",
    "dev:stop": "lsof -ti:3000 | xargs kill -9 || echo 'No hay proceso en el puerto 3000'",
    "dev:r": "npm run dev:stop && npm run dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "vercel-build": "prisma generate && node scripts/vercel-deploy.js && npm run db:seed && next build --turbopack",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "seed:products": "tsx prisma/seed-products.ts",
    "retc:import": "tsx prisma/import-retc.ts",
    "db:reset": "prisma migrate reset --force && npm run db:seed",
    "db:reset:prod": "node scripts/reset-prod-db.js",
    "db:reset:safe": "node scripts/reset-prod-db.js",
    "db:deploy": "prisma migrate deploy && npm run db:seed",
    "test": "node scripts/setup-test-db.js && jest",
    "test:watch": "jest --watch",
    "test:coverage": "node scripts/setup-test-db.js && jest --coverage",
    "test:only": "jest",
    "test:ci": "npm run test:coverage && npm run test:e2e",
    "test:unit": "jest src/__tests__/components src/__tests__/utils",
    "test:integration": "jest src/__tests__/components/DashboardIntegration.test.tsx",
    "test:api": "jest __tests__/api",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "npm run test && npm run test:e2e",
    "generate:vapid": "node scripts/generate-vapid-keys.js",
    "verify:pre-prod": "node scripts/verify-pre-prod.js"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.0",
    "@aws-sdk/client-s3": "^3.922.0",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-pdf/renderer": "^4.3.1",
    "@tanstack/react-query": "^5.90.5",
    "@tanstack/react-query-devtools": "^5.90.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/leaflet": "^1.9.21",
    "@types/pdfkit": "^0.17.3",
    "@types/qrcode": "^1.5.6",
    "@types/react-google-recaptcha": "^2.1.9",
    "bcryptjs": "^3.0.2",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "csv-parser": "^3.2.0",
    "date-fns": "^4.1.0",
    "exceljs": "^4.4.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^3.0.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.552.0",
    "mailgun.js": "^12.1.1",
    "next": "^16.0.5",
    "next-auth": "^5.0.0-beta.29",
    "pdfkit": "^0.17.2",
    "puppeteer": "^24.29.0",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "react": "19.1.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "19.1.0",
    "react-dropzone": "^14.3.8",
    "react-gauge-component": "^1.2.64",
    "react-google-recaptcha": "^3.1.0",
    "react-hook-form": "^7.65.0",
    "react-hot-toast": "^2.6.0",
    "react-is": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.3.0",
    "sharp": "^0.34.4",
    "sonner": "^2.0.7",
    "sweetalert2": "^11.26.3",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@next/eslint-plugin-next": "^16.1.6",
    "@playwright/test": "^1.56.1",
    "@prisma/client": "^6.18.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "baseline-browser-mapping": "^2.10.0",
    "eslint": "^9",
    "eslint-config-next": "^16.0.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "msw": "^2.11.6",
    "node-mocks-http": "^1.17.2",
    "prettier": "^3.7.4",
    "prisma": "^6.18.0",
    "tailwindcss": "^4.2.1",
    "ts-morph": "^27.0.2",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "typescript-eslint": "^8.56.1"
  },
  "overrides": {
    "glob": "^10.4.5",
    "rimraf": "^5.0.10",
    "inflight": "npm:@zkochan/inflight@^1.0.2",
    "lodash.isequal": "npm:fast-deep-equal@^3.1.3",
    "fstream": "npm:tar-stream@^3.1.7"
  }
}
