/**
 * Tests unitarios para cron job de verificación de vencimientos
 * HU-016: Validación Documental de Transportistas y Gestores
 */

import { GET } from '@/app/api/cron/vencimientos/route'
import { prisma } from '@/lib/prisma'
import {
  sendVencimiento30DiasEmail,
  sendVencimiento15DiasEmail,
  sendSuspensionEmail
} from '@/lib/emails/send'

// Mocks
jest.mock('@/lib/prisma', () => ({
  prisma: {
    documentoVerificacion: {
      findMany: jest.fn(),
      update: jest.fn(),
    },
    alertaVencimiento: {
      create: jest.fn(),
    },
    user: {
      update: jest.fn(),
    }
  }
}))

jest.mock('@/lib/emails/send', () => ({
  sendVencimiento30DiasEmail: jest.fn(),
  sendVencimiento15DiasEmail: jest.fn(),
  sendSuspensionEmail: jest.fn(),
}))

const mockPrisma = prisma as jest.Mocked<typeof prisma>
const mockSendVencimiento30DiasEmail = sendVencimiento30DiasEmail as jest.MockedFunction<typeof sendVencimiento30DiasEmail>
const mockSendVencimiento15DiasEmail = sendVencimiento15DiasEmail as jest.MockedFunction<typeof sendVencimiento15DiasEmail>
const mockSendSuspensionEmail = sendSuspensionEmail as jest.MockedFunction<typeof sendSuspensionEmail>

describe('Cron Job - Verificación de Vencimientos', () => {
  beforeEach(() => {
    jest.clearAllMocks()
    
    // Mock Date.now() para tener fechas consistentes en los tests
    jest.useFakeTimers()
    jest.setSystemTime(new Date('2025-01-01T00:00:00Z'))
  })

  afterEach(() => {
    jest.useRealTimers()
  })

  describe('GET /api/cron/vencimientos', () => {
    it('debería procesar documentos que vencen en 30 días', async () => {
      const fecha30Dias = new Date('2025-01-31') // 30 días desde 2025-01-01
      
      const documentos30Dias = [
        {
          id: 'doc-1',
          userId: 'user-1',
          tipoDocumento: 'AUTORIZACION_SANITARIA_TRANSPORTE',
          fechaVencimiento: fecha30Dias,
          nivelAlertaVencimiento: 'VIGENTE',
          user: {
            id: 'user-1',
            nombre: 'Juan Pérez',
            email: 'juan@example.com'
          }
        }
      ]

      mockPrisma.documentoVerificacion.findMany
        .mockResolvedValueOnce(documentos30Dias as any) // Para 30 días
        .mockResolvedValueOnce([]) // Para 15 días
        .mockResolvedValueOnce([]) // Para vencidos

      mockPrisma.documentoVerificacion.update.mockResolvedValue({} as any)
      mockPrisma.alertaVencimiento.create.mockResolvedValue({} as any)
      mockSendVencimiento30DiasEmail.mockResolvedValue(undefined)

      const response = await GET()
      const data = await response.json()

      expect(response.status).toBe(200)
      expect(data.procesados).toBe(1)
      expect(data.alertas30Dias).toBe(1)
      expect(data.alertas15Dias).toBe(0)
      expect(data.suspensiones).toBe(0)

      // Verificar que se actualizó el nivel de alerta
      expect(mockPrisma.documentoVerificacion.update).toHaveBeenCalledWith({
        where: { id: 'doc-1' },
        data: { nivelAlertaVencimiento: 'ALERTA' }
      })

      // Verificar que se creó la alerta
      expect(mockPrisma.alertaVencimiento.create).toHaveBeenCalledWith({
        data: {
          documentoId: 'doc-1',
          tipoAlerta: 'VENCIMIENTO_30_DIAS',
          fechaAlerta: expect.any(Date),
          enviado: true
        }
      })

      // Verificar que se envió el email
      expect(mockSendVencimiento30DiasEmail).toHaveBeenCalledWith(
        'juan@example.com',
        'Juan Pérez',
        'AUTORIZACION_SANITARIA_TRANSPORTE',
        fecha30Dias
      )
    })

    it('debería procesar documentos que vencen en 15 días', async () => {
      const fecha15Dias = new Date('2025-01-16') // 15 días desde 2025-01-01
      
      const documentos15Dias = [
        {
          id: 'doc-2',
          userId: 'user-2',
          tipoDocumento: 'REVISION_TECNICA',
          fechaVencimiento: fecha15Dias,
          nivelAlertaVencimiento: 'ALERTA',
          user: {
            id: 'user-2',
            nombre: 'María González',
            email: 'maria@example.com'
          }
        }
      ]

      mockPrisma.documentoVerificacion.findMany
        .mockResolvedValueOnce([]) // Para 30 días
        .mockResolvedValueOnce(documentos15Dias as any) // Para 15 días
        .mockResolvedValueOnce([]) // Para vencidos

      mockPrisma.documentoVerificacion.update.mockResolvedValue({} as any)
      mockPrisma.alertaVencimiento.create.mockResolvedValue({} as any)
      mockSendVencimiento15DiasEmail.mockResolvedValue(undefined)

      const response = await GET()
      const data = await response.json()

      expect(response.status).toBe(200)
      expect(data.alertas30Dias).toBe(0)
      expect(data.alertas15Dias).toBe(1)
      expect(data.suspensiones).toBe(0)

      // Verificar que se actualizó el nivel de alerta a CRITICO
      expect(mockPrisma.documentoVerificacion.update).toHaveBeenCalledWith({
        where: { id: 'doc-2' },
        data: { nivelAlertaVencimiento: 'CRITICO' }
      })

      // Verificar que se envió el email crítico
      expect(mockSendVencimiento15DiasEmail).toHaveBeenCalledWith(
        'maria@example.com',
        'María González',
        'REVISION_TECNICA',
        fecha15Dias
      )
    })

    it('debería procesar documentos vencidos y suspender usuarios', async () => {
      const fechaVencida = new Date('2024-12-31') // Vencido desde 2025-01-01
      
      const documentosVencidos = [
        {
          id: 'doc-3',
          userId: 'user-3',
          tipoDocumento: 'PERMISO_CIRCULACION',
          fechaVencimiento: fechaVencida,
          nivelAlertaVencimiento: 'CRITICO',
          user: {
            id: 'user-3',
            nombre: 'Carlos López',
            email: 'carlos@example.com',
            estadoVerificacion: 'VERIFICADO'
          }
        }
      ]

      mockPrisma.documentoVerificacion.findMany
        .mockResolvedValueOnce([]) // Para 30 días
        .mockResolvedValueOnce([]) // Para 15 días
        .mockResolvedValueOnce(documentosVencidos as any) // Para vencidos

      mockPrisma.documentoVerificacion.update.mockResolvedValue({} as any)
      mockPrisma.alertaVencimiento.create.mockResolvedValue({} as any)
      mockPrisma.user.update.mockResolvedValue({} as any)
      mockSendSuspensionEmail.mockResolvedValue(undefined)

      const response = await GET()
      const data = await response.json()

      expect(response.status).toBe(200)
      expect(data.alertas30Dias).toBe(0)
      expect(data.alertas15Dias).toBe(0)
      expect(data.suspensiones).toBe(1)

      // Verificar que se actualizó el documento a VENCIDO
      expect(mockPrisma.documentoVerificacion.update).toHaveBeenCalledWith({
        where: { id: 'doc-3' },
        data: { 
          nivelAlertaVencimiento: 'VENCIDO',
          estadoValidacion: 'VENCIDO'
        }
      })

      // Verificar que se suspendió el usuario
      expect(mockPrisma.user.update).toHaveBeenCalledWith({
        where: { id: 'user-3' },
        data: { estadoVerificacion: 'SUSPENDIDO' }
      })

      // Verificar que se envió el email de suspensión
      expect(mockSendSuspensionEmail).toHaveBeenCalledWith(
        'carlos@example.com',
        'Carlos López',
        'PERMISO_CIRCULACION'
      )
    })

    it('debería procesar múltiples documentos de diferentes tipos', async () => {
      const fecha30Dias = new Date('2025-01-31')
      const fecha15Dias = new Date('2025-01-16')
      const fechaVencida = new Date('2024-12-31')

      const documentos30Dias = [
        {
          id: 'doc-1',
          userId: 'user-1',
          tipoDocumento: 'AUTORIZACION_SANITARIA_TRANSPORTE',
          fechaVencimiento: fecha30Dias,
          nivelAlertaVencimiento: 'VIGENTE',
          user: { id: 'user-1', nombre: 'Juan', email: 'juan@example.com' }
        },
        {
          id: 'doc-2',
          userId: 'user-2',
          tipoDocumento: 'RCA',
          fechaVencimiento: fecha30Dias,
          nivelAlertaVencimiento: 'VIGENTE',
          user: { id: 'user-2', nombre: 'Ana', email: 'ana@example.com' }
        }
      ]

      const documentos15Dias = [
        {
          id: 'doc-3',
          userId: 'user-3',
          tipoDocumento: 'REVISION_TECNICA',
          fechaVencimiento: fecha15Dias,
          nivelAlertaVencimiento: 'ALERTA',
          user: { id: 'user-3', nombre: 'Pedro', email: 'pedro@example.com' }
        }
      ]

      const documentosVencidos = [
        {
          id: 'doc-4',
          userId: 'user-4',
          tipoDocumento: 'PERMISO_CIRCULACION',
          fechaVencimiento: fechaVencida,
          nivelAlertaVencimiento: 'CRITICO',
          user: { id: 'user-4', nombre: 'Luis', email: 'luis@example.com', estadoVerificacion: 'VERIFICADO' }
        }
      ]

      mockPrisma.documentoVerificacion.findMany
        .mockResolvedValueOnce(documentos30Dias as any)
        .mockResolvedValueOnce(documentos15Dias as any)
        .mockResolvedValueOnce(documentosVencidos as any)

      mockPrisma.documentoVerificacion.update.mockResolvedValue({} as any)
      mockPrisma.alertaVencimiento.create.mockResolvedValue({} as any)
      mockPrisma.user.update.mockResolvedValue({} as any)
      
      mockSendVencimiento30DiasEmail.mockResolvedValue(undefined)
      mockSendVencimiento15DiasEmail.mockResolvedValue(undefined)
      mockSendSuspensionEmail.mockResolvedValue(undefined)

      const response = await GET()
      const data = await response.json()

      expect(response.status).toBe(200)
      expect(data.procesados).toBe(4)
      expect(data.alertas30Dias).toBe(2)
      expect(data.alertas15Dias).toBe(1)
      expect(data.suspensiones).toBe(1)

      // Verificar que se enviaron todos los emails
      expect(mockSendVencimiento30DiasEmail).toHaveBeenCalledTimes(2)
      expect(mockSendVencimiento15DiasEmail).toHaveBeenCalledTimes(1)
      expect(mockSendSuspensionEmail).toHaveBeenCalledTimes(1)
    })

    it('debería manejar errores de email sin fallar el proceso', async () => {
      const fecha30Dias = new Date('2025-01-31')
      
      const documentos = [
        {
          id: 'doc-1',
          userId: 'user-1',
          tipoDocumento: 'AUTORIZACION_SANITARIA_TRANSPORTE',
          fechaVencimiento: fecha30Dias,
          nivelAlertaVencimiento: 'VIGENTE',
          user: { id: 'user-1', nombre: 'Juan', email: 'juan@example.com' }
        }
      ]

      mockPrisma.documentoVerificacion.findMany
        .mockResolvedValueOnce(documentos as any)
        .mockResolvedValueOnce([])
        .mockResolvedValueOnce([])

      mockPrisma.documentoVerificacion.update.mockResolvedValue({} as any)
      mockPrisma.alertaVencimiento.create.mockResolvedValue({} as any)
      
      // Simular error en envío de email
      mockSendVencimiento30DiasEmail.mockRejectedValue(new Error('Email error'))

      const response = await GET()
      const data = await response.json()

      // El proceso debería continuar aunque falle el email
      expect(response.status).toBe(200)
      expect(data.procesados).toBe(1)
      expect(data.alertas30Dias).toBe(1)
      expect(data.errores).toBe(1)

      // Verificar que se actualizó la base de datos
      expect(mockPrisma.documentoVerificacion.update).toHaveBeenCalled()
    })

    it('debería manejar errores de base de datos', async () => {
      mockPrisma.documentoVerificacion.findMany.mockRejectedValue(new Error('Database error'))

      const response = await GET()
      const data = await response.json()

      expect(response.status).toBe(500)
      expect(data.error).toBe('Error interno del servidor')
    })

    it('debería no procesar documentos que ya tienen el nivel de alerta correcto', async () => {
      const fecha30Dias = new Date('2025-01-31')
      
      const documentos = [
        {
          id: 'doc-1',
          userId: 'user-1',
          tipoDocumento: 'AUTORIZACION_SANITARIA_TRANSPORTE',
          fechaVencimiento: fecha30Dias,
          nivelAlertaVencimiento: 'ALERTA', // Ya tiene alerta de 30 días
          user: { id: 'user-1', nombre: 'Juan', email: 'juan@example.com' }
        }
      ]

      mockPrisma.documentoVerificacion.findMany
        .mockResolvedValueOnce([]) // Para 30 días (filtrado por VIGENTE)
        .mockResolvedValueOnce([])
        .mockResolvedValueOnce([])

      const response = await GET()
      const data = await response.json()

      expect(response.status).toBe(200)
      expect(data.procesados).toBe(0)
      expect(data.alertas30Dias).toBe(0)

      // No debería haber actualizado ni enviado emails
      expect(mockPrisma.documentoVerificacion.update).not.toHaveBeenCalled()
      expect(mockSendVencimiento30DiasEmail).not.toHaveBeenCalled()
    })
  })

  describe('Cálculo de fechas', () => {
    it('debería calcular correctamente fechas de vencimiento', () => {
      const hoy = new Date('2025-01-01')
      const fecha30Dias = new Date(hoy)
      fecha30Dias.setDate(hoy.getDate() + 30)
      
      const fecha15Dias = new Date(hoy)
      fecha15Dias.setDate(hoy.getDate() + 15)

      expect(fecha30Dias.toISOString().split('T')[0]).toBe('2025-01-31')
      expect(fecha15Dias.toISOString().split('T')[0]).toBe('2025-01-16')
    })

    it('debería manejar cambios de mes correctamente', () => {
      jest.setSystemTime(new Date('2025-01-31T00:00:00Z'))
      
      const hoy = new Date('2025-01-31')
      const fecha30Dias = new Date(hoy)
      fecha30Dias.setDate(hoy.getDate() + 30)
      
      // Debería pasar a marzo (febrero tiene 28 días en 2025)
      expect(fecha30Dias.getMonth()).toBe(2) // Marzo (0-indexed)
    })
  })

  describe('Filtros de consulta', () => {
    it('debería usar filtros correctos para documentos de 30 días', () => {
      // Este test verifica que los filtros de Prisma sean correctos
      // En una implementación real, verificaríamos los parámetros exactos
      expect(mockPrisma.documentoVerificacion.findMany).toBeDefined()
    })

    it('debería incluir solo documentos aprobados', () => {
      // Los documentos deben estar aprobados para ser considerados para vencimiento
      expect(mockPrisma.documentoVerificacion.findMany).toBeDefined()
    })
  })
})
