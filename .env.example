# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Base de datos local para desarrollo
DATABASE_URL=postgresql://mac@localhost:5432/trazambiental?schema=public

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="tu-secreto-super-seguro"

# Configuración de desarrollo
NODE_ENV="development"

# Inicialización de Base de Datos y Seeds
# true: Ejecuta seeds (desarrollo o PRIMER deploy en producción)
# false: Solo migraciones, NO seeds (deploys subsecuentes en producción)
INITIALIZE_DB_AND_SEED_DATA="true"

# Admins en producción (opción 1 - recomendado)
# Arreglo JSON con admins: [{"email":"admin@dominio.com","password":"...","name":"...","rut":"..."}]
ADMIN_USERS_JSON='[]'

# Admins en producción (opción 2 - alternativo)
ADMIN_EMAIL="admin@trazambiental.com"
ADMIN_PASSWORD="tu-password-seguro"
ADMIN_NAME="Admin Principal"
ADMIN_RUT="16746438-6"

# Google reCAPTCHA v2
NEXT_PUBLIC_RECAPTCHA_SITE_KEY="tu-site-key"
RECAPTCHA_SECRET_KEY="tu-secret-key"

# Mailgun Email Service (https://app.mailgun.com/)
MAILGUN_API_KEY="tu-mailgun-api-key"
MAILGUN_DOMAIN="tu-dominio.mailgun.org"
MAILGUN_API_URL="https://api.mailgun.net"
FROM_EMAIL="noreply@tu-dominio.com"
FROM_NAME="TrazAmbiental"

# 🐳 CONFIGURACIÓN DOCKER (Opcional si usas Docker Compose)
# POSTGRES_USER=kirlts
# POSTGRES_PASSWORD=devpassword123
# POSTGRES_DB=trazambiental_db
# Para usar con Docker Compose, descomenta arriba y usa este DATABASE_URL:
# DATABASE_URL=postgresql://kirlts:devpassword123@db:5432/trazambiental_db?schema=public
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
